{
	"name": "@nomideusz/svelte-scheduler",
	"version": "0.1.0",
	"description": "Booking and scheduling logic library for Svelte 5 — tour slots, pricing, cancellation policies.",
	"type": "module",
	"license": "MIT",
	"svelte": "./dist/index.js",
	"types": "./dist/index.d.ts",
	"exports": {
		".": {
			"types": "./dist/index.d.ts",
			"svelte": "./dist/index.js",
			"default": "./dist/index.js"
		}
	},
	"files": [
		"dist",
		"!dist/**/*.test.*",
		"!dist/**/*.spec.*"
	],
	"scripts": {
		"dev": "vite dev",
		"build": "vite build",
		"package": "svelte-kit sync && svelte-package",
		"prepublishOnly": "npm run package",
		"preview": "vite preview",
		"prepare": "svelte-kit sync || echo ''",
		"check": "svelte-kit sync && svelte-check --tsconfig ./tsconfig.json",
		"check:watch": "svelte-kit sync && svelte-check --tsconfig ./tsconfig.json --watch",
		"test": "vitest run --passWithNoTests",
		"test:watch": "vitest"
	},
	"peerDependencies": {
		"svelte": "^5.0.0",
		"@nomideusz/svelte-calendar": "^0.6.0"
	},
	"devDependencies": {
		"@nomideusz/svelte-calendar": "workspace:*",
		"@sveltejs/adapter-auto": "^7.0.0",
		"@sveltejs/kit": "^2.50.2",
		"@sveltejs/package": "^2.5.7",
		"@sveltejs/vite-plugin-svelte": "^6.2.4",
		"svelte": "^5.51.0",
		"svelte-check": "^4.3.6",
		"typescript": "^5.9.3",
		"vite": "^7.3.1",
		"vitest": "^4.0.18"
	},
	"keywords": [
		"svelte",
		"scheduler",
		"booking",
		"tours",
		"pricing",
		"cancellation",
		"svelte5"
	]
}
