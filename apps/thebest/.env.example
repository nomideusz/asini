# PostgreSQL connection string
DATABASE_URL=postgresql://user:password@localhost:5432/thebest

# Stripe (get from dashboard.stripe.com)
STRIPE_SECRET_KEY=sk_test_...
STRIPE_PUBLISHABLE_KEY=pk_test_...
STRIPE_WEBHOOK_SECRET=whsec_...

# Resend (get from resend.com)
RESEND_API_KEY=re_...

# App origin — used for Stripe redirect URLs
# Dev: http://localhost:5173
# Prod: https://thebest.travel
ORIGIN=https://thebest.travel

# S3-compatible storage (Cloudflare R2, AWS S3, MinIO, etc.)
# Get from your storage provider dashboard
S3_ENDPOINT=https://xxx.r2.cloudflarestorage.com
S3_REGION=auto
S3_BUCKET=thebest-media
S3_ACCESS_KEY_ID=
S3_SECRET_ACCESS_KEY=
S3_PUBLIC_URL=https://media.thebest.travel
